PORT=5550
CORS_ORIGIN=*

# Preferred AI API via Groq
# Create an API key from https://console.groq.com/
CHATBOT_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional generic override if you want another OpenAI-compatible provider
# CHATBOT_PROVIDER=custom
# CHATBOT_API_URL=https://example.com/v1/chat/completions
# CHATBOT_API_KEY=your_custom_api_key_here
# CHATBOT_MODEL=your_model_name_here

# Optional fallback via OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# Optional app attribution headers for OpenRouter/custom providers
OPENROUTER_HTTP_REFERER=http://localhost:8081
OPENROUTER_APP_TITLE=GP AAC Chatbot
