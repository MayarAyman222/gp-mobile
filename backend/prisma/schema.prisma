generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Icon {
  id            Int       @id @default(autoincrement())
  title_en      String    @unique
  title_ar      String
  title_fr      String
  title_es      String
  expression_en String
  expression_ar String
  expression_fr String
  expression_es String
  createdAt     DateTime  @default(now())
  iconName      String?   // nullable
  imgUrl        String?   // nullable
  category      String
  subIcons      SubIcon[]
}

model SubIcon {
  id            Int       @id @default(autoincrement())
  title_en      String
  title_ar      String
  title_fr      String
  title_es      String
  expression_en String
  expression_ar String
  expression_fr String
  expression_es String
  imageUrl      String
  iconId        Int
  createdAt     DateTime  @default(now())
  icon          Icon      @relation(fields: [iconId], references: [id])
  @@unique([title_en, iconId])
}


model User {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  condition   Condition
  createdAt   DateTime @default(now())
}

enum Condition {
  AUTISM
  STROKE
  ALZHEIMER
  SPEECH_DELAY
  OTHER
}

