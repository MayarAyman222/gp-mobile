{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_DEV_API_BASE_URL": "http://168.231.101.20:5550",
        "EXPO_PUBLIC_PROD_API_BASE_URL": "http://168.231.101.20:5550"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_PROD_API_BASE_URL": "http://168.231.101.20:5550",
        "EXPO_PUBLIC_DEV_API_BASE_URL": "http://168.231.101.20:5550"
      }
    },
    "production-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_PROD_API_BASE_URL": "http://168.231.101.20:5550",
        "EXPO_PUBLIC_DEV_API_BASE_URL": "http://168.231.101.20:5550"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_PROD_API_BASE_URL": "http://168.231.101.20:5550",
        "EXPO_PUBLIC_DEV_API_BASE_URL": "http://168.231.101.20:5550"
      }
    },
    "ios-simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_DEV_API_BASE_URL": "http://168.231.101.20:5550",
        "EXPO_PUBLIC_PROD_API_BASE_URL": "http://168.231.101.20:5550"
      }
    }
  }
}
